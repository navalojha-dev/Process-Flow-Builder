# Process Flow Builder — environment variables
#
# COPY to `.env` (git-ignored) and fill in. Never commit `.env`.
#     cp .env.example .env

# ─── LLM provider keys ─────────────────────────────────────────────────
# Anthropic Claude — https://console.anthropic.com/settings/keys (paid)
ANTHROPIC_API_KEY=

# Google Gemini via AI Studio — https://aistudio.google.com/apikey (free tier)
GEMINI_API_KEY=

# ─── Defaults ──────────────────────────────────────────────────────────
PF_PROVIDER=gemini
# PF_GEMINI_MODEL=gemini-2.5-flash
# PF_ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
